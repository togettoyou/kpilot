# kpilot — local development env file
#
# Copy this to .env in the project root. Both `go run ./cmd/server` and
# `go run ./cmd/worker` will pick it up automatically (godotenv.Load in
# pkg/server/config + pkg/worker/config). Real env vars set in the shell
# or pod take precedence — .env only fills the gaps.

# ─── Server ────────────────────────────────────────────────────────────────

# HTTP_ADDR=:8080
# GRPC_ADDR=:9090
# DSN=postgres://kpilot:kpilot123@localhost:5432/kpilot?sslmode=disable
# ADMIN_USERNAME=admin
# ADMIN_PASSWORD=admin123

# JWT signing key. Set this in production (otherwise tokens are
# invalidated on every Server restart). 32 random hex bytes is fine.
# JWT_SECRET=

# Comma-separated allowed origins. Empty = dev mode (any origin).
# CORS_ORIGINS=https://kpilot.example.com

# ─── Worker ────────────────────────────────────────────────────────────────

# Server's gRPC address from the Worker's perspective.
# SERVER_ADDR=localhost:9090

# The cluster token (one-time-shown when creating a cluster in the UI).
# CLUSTER_TOKEN=

# Worker's persistent data root. Default is ./data (relative to the
# Worker's working directory) for friction-free local dev. In
# production set this to a PVC mount, e.g. /var/lib/kpilot — chart
# .tgz cache and Helm's repo state both live under it.
# DATA_DIR=./data

# Helm-side overrides (advanced). When set, take precedence over
# DATA_DIR for Helm's repo config and cache.
# HELM_REPOSITORY_CONFIG=/var/lib/kpilot/helm/repositories.yaml
# HELM_REPOSITORY_CACHE=/var/lib/kpilot/helm/cache
